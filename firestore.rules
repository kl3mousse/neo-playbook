rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Default: deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper: check if user is admin
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Games collection: anyone can read, admin can write
    match /games/{gameId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Command.dat data: anyone can read, admin can write
    match /command_dat/{romset} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // DIP settings: anyone can read, admin can write
    match /dip_settings/{romset} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User profiles: owner can read/write own profile
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;

      // Favorites subcollection: owner only
      match /favorites/{gameId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }

      // Collection subcollection: owner only
      match /collection/{itemId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }

    // Community notes: anyone can read, auth can create, owner can update/delete
    match /community_notes/{noteId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.user_id == request.auth.uid;
      allow delete: if request.auth != null
                    && (resource.data.user_id == request.auth.uid || isAdmin());
    }

    // Scores: anyone can read, auth can create, owner or admin can delete
    match /scores/{scoreId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.user_id == request.auth.uid;
      allow delete: if request.auth != null
                    && (resource.data.user_id == request.auth.uid || isAdmin());
      // Only admin can verify (update verified_at)
      allow update: if isAdmin();
    }
  }
}
