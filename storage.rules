rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Default: deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Game images: anyone can read, admin can write
    match /images/{gameId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.admin == true;
    }

    // Profile pictures: anyone can read, owner can write
    match /profile_pics/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && fileName == (request.auth.uid + '.jpg')
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Score proof photos: anyone can read, owner can write
    match /scores/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
